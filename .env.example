# Copy to .env.local or .dev.vars for local development.
# Do not commit real CPA keys.

# Recommended for local development. This avoids JSON quoting/newline issues.
CPA_INSTANCE_ID=main
CPA_INSTANCE_NAME=Main CPA
CPA_BASE_URL=https://cpa.example.com
CPA_ACCESS_KEY=replace-me
ADMIN_PASSWORD=change-this-password

# Alternative for multiple instances. Keep it on one line in .dev.vars.
# CPA_INSTANCES_JSON=[{"id":"main","name":"Main CPA","baseUrl":"https://cpa.example.com","accessKey":"replace-me","enabled":true}]
#
# Alternative for production if you want multiline JSON locally:
# encode JSON as base64 and set CPA_INSTANCES_JSON_B64.
# CPA_INSTANCES_JSON_B64=W3siaWQiOiJtYWluIiwibmFtZSI6Ik1haW4gQ1BBIiwiYmFzZVVybCI6Imh0dHBzOi8vY3BhLmV4YW1wbGUuY29tIiwiYWNjZXNzS2V5IjoicmVwbGFjZS1tZSIsImVuYWJsZWQiOnRydWV9XQ==

MONITOR_TARGET_URL=https://chatgpt.com/backend-api/wham/usage
CHECK_TIMEOUT_MS=30000
CHECK_CONCURRENCY=8
SKIP_DISABLED=true
