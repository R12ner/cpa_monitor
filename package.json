{
  "name": "cpa-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public",
    "deploy": "wrangler pages deploy public",
    "check": "node --check functions/api/[[path]].js && node --check public/app.js",
    "kv:create": "wrangler kv namespace create CPA_MONITOR_KV",
    "kv:list": "wrangler kv namespace list",
    "kv:bind": "node scripts/set-kv-binding.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.18.0"
  }
}
